# ─── Obligatoires ────────────────────────────────────────────────────────────

# Fourni automatiquement par Railway si tu utilises le plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/factureasy

# Clé de signature JWT — génère avec : node -e "require('crypto').randomBytes(48).toString('hex')"
JWT_SECRET=CHANGE_MOI_EN_PROD_cle_aleatoire_48_octets

# ⚠️  CRITIQUE — sans ça, le frontend Vercel est bloqué par CORS
# Mettre l'URL exacte de ton frontend (sans slash final)
# Ex : https://factureasy.vercel.app ou https://app.factureasy.fr
ALLOWED_ORIGINS=https://app.factureasy.fr

# Port (Railway l'injecte automatiquement, ne pas changer)
PORT=3001

# ─── Emails (relances automatiques) ──────────────────────────────────────────

# Clé Resend — https://resend.com → API Keys → Create API Key
# Si absent : les relances s'affichent dans les logs mais n'arrivent jamais aux clients
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── API SIRENE (INSEE) ───────────────────────────────────────────────────────

# Token INSEE pour l'autocomplétion SIRET — https://portail.api.insee.fr
# Si absent : fonctionne en anonyme, quota ~500 req/jour (insuffisant en prod)
INSEE_API_TOKEN=

# ─── Chorus Pro ───────────────────────────────────────────────────────────────

# Laisser vide = mode mock (factures créées localement, pas transmises à Chorus)
# Pour la production réelle : récupérer sur https://piste.gouv.fr
CHORUS_CLIENT_ID=
CHORUS_CLIENT_SECRET=

# ─── Admin ────────────────────────────────────────────────────────────────────

# Secret pour accéder au dashboard /admin — génère une valeur aléatoire forte (>= 32 caractères)
ADMIN_SECRET=CHANGE_MOI_EN_PROD_secret_aleatoire_48_octets_minimum

# ─── Stripe ───────────────────────────────────────────────────────────────────

# Clé secrète Stripe — https://dashboard.stripe.com/apikeys
# sk_test_xxx en développement, sk_live_xxx en production
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Secret webhook — Stripe Dashboard → Developers → Webhooks → ton endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Price IDs — obtenus après avoir exécuté node stripe/setup.js
STRIPE_PRICE_SOLO=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_EQUIPE=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_BUSINESS=price_xxxxxxxxxxxxxxxxxxxx

# ─── Optionnel ────────────────────────────────────────────────────────────────

# Délai avant relance automatique (défaut : 30 jours)
RELANCE_DELAI_JOURS=30
